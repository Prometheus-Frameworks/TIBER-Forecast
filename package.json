{
  "name": "point-prediction-model",
  "version": "0.1.0",
  "private": true,
  "description": "Tiber in-season fantasy scoring engine (xFPG, replacement baselines, VORP, weekly/ROS utilities).",
  "exports": {
    ".": "./src/public/index.ts"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "start:api": "tsx src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "export:point-scenario-lab": "tsx scripts/exportPointScenarioLab.ts",
    "evaluate:run2-coverage-gate": "tsx scripts/runRun2CoverageGateEvaluation.ts",
    "evaluate:player-season-coverage-gate": "tsx scripts/runPlayerSeasonCoverageGateEvaluation.ts",
    "scaffold:player-history-features": "tsx scripts/runPlayerHistoryFeatureScaffold.ts",
    "dryrun:player-history-matrix": "tsx scripts/runPlayerHistoryExperimentDryRunMatrix.ts",
    "generate:player-history-run-mirrors": "tsx scripts/buildPlayerHistoryRunPopulationMirrors.ts",
    "gate:player-history-population": "tsx scripts/runPlayerHistoryPopulationGates.ts",
    "rerun:run2-comparison-full-coverage": "tsx scripts/runRun2ComparisonRerun.ts",
    "backtest:seasonal-ppr": "tsx scripts/runSeasonalPprBacktest.ts",
    "forecast:seasonal-ppr": "tsx scripts/runSeasonalPprBacktest.ts",
    "verify:seasonal-ppr": "tsx scripts/runSeasonalPprBacktest.ts --ppr-artifact=exports/promoted/nfl/player_weekly_ppr_outcomes_v1.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tsx": "^4.19.2",
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

{
  "name": "point-prediction-model",
  "version": "0.1.0",
  "private": true,
  "description": "Tiber in-season fantasy scoring engine (xFPG, replacement baselines, VORP, weekly/ROS utilities).",
  "exports": {
    ".": "./src/public/index.ts"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "start:api": "tsx src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "export:point-scenario-lab": "tsx scripts/exportPointScenarioLab.ts",
    "evaluate:run2-coverage-gate": "tsx scripts/runRun2CoverageGateEvaluation.ts",
    "evaluate:player-season-coverage-gate": "tsx scripts/runPlayerSeasonCoverageGateEvaluation.ts",
    "scaffold:player-history-features": "tsx scripts/runPlayerHistoryFeatureScaffold.ts",
    "dryrun:player-history-matrix": "tsx scripts/runPlayerHistoryExperimentDryRunMatrix.ts",
    "generate:player-history-run-mirrors": "tsx scripts/buildPlayerHistoryRunPopulationMirrors.ts",
    "gate:player-history-population": "tsx scripts/runPlayerHistoryPopulationGates.ts",
    "gate:player-history-promoted-source": "tsx scripts/runPlayerHistoryPromotedSourceGate.ts",
    "refresh:player-history-promoted-mirrors": "tsx scripts/runPlayerHistoryPromotedMirrorRefresh.ts",
    "refresh:player-history-2024-from-2021-2023-mirrors": "tsx scripts/runPlayerHistory2024From2021_2023MirrorRefresh.ts",
    "validate:player-history-2024-from-2021-2023-additional": "tsx scripts/runPlayerHistory2024From2021_2023AdditionalValidation.ts",
    "review:player-history-2024-from-2021-2023-threshold": "tsx scripts/runPlayerHistory2024From2021_2023ThresholdReview.ts",
    "review:player-history-production-binding": "tsx scripts/runPlayerHistoryProductionBindingReview.ts",
    "review:player-history-production-binding-implementation": "tsx scripts/runPlayerHistoryProductionBindingImplementation.ts",
    "verify:player-history-production-binding-activation": "tsx scripts/runPlayerHistoryProductionBindingActivationVerification.ts",
    "experiment:player-history-controlled-run": "tsx scripts/runPlayerHistoryControlledRun.ts",
    "experiment:player-history-robustness": "tsx scripts/runPlayerHistoryRobustnessChecks.ts",
    "experiment:player-history-promoted-controlled-rerun": "tsx scripts/runPlayerHistoryPromotedControlledRerun.ts",
    "replay:player-history-contract-v0": "tsx scripts/runPlayerHistoryContractV0Replay.ts",
    "refresh:rookie-transition-profile-mirror": "tsx scripts/refreshRookieTransitionProfileMirror.ts",
    "rerun:run2-comparison-full-coverage": "tsx scripts/runRun2ComparisonRerun.ts",
    "backtest:seasonal-ppr": "tsx scripts/runSeasonalPprBacktest.ts",
    "forecast:seasonal-ppr": "tsx scripts/runSeasonalPprBacktest.ts",
    "verify:seasonal-ppr": "tsx scripts/runSeasonalPprBacktest.ts --ppr-artifact=exports/promoted/nfl/player_weekly_ppr_outcomes_v1.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tsx": "^4.19.2",
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
